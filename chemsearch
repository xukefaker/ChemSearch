#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PATH="${CHEMSEARCH_VENV_PATH:-}"
if [[ -z "$VENV_PATH" && -f "$ROOT/.chemsearch-venv" ]]; then
  VENV_PATH="$(<"$ROOT/.chemsearch-venv")"
fi
VENV_PATH="${VENV_PATH:-$ROOT/.venv}"
CMD="$VENV_PATH/bin/chemsearch"
LOCAL_NODE_BIN="$ROOT/.local/node/current/bin"

if [[ -x "$LOCAL_NODE_BIN/node" ]]; then
  export PATH="$LOCAL_NODE_BIN:$PATH"
fi

if [[ ! -x "$CMD" ]]; then
  printf 'ChemSearch is not installed yet. Run ./scripts/install.sh first.\n' >&2
  exit 1
fi

exec "$CMD" "$@"
