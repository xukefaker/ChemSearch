# Required. Your OpenAI or OpenAI-compatible API key.
OPENAI_API_KEY=

# Keep this value for OpenAI. Change it only if you use a compatible proxy.
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model for question answering.
OPENAI_MODEL=gpt-4o-mini

# Local storage for PDFs, parsed text, and indexes.
PAPERSCOUT_DATA_DIR=./data

# Use cpu for widest compatibility. Change to cuda if NVIDIA CUDA works on your machine.
PAPERSCOUT_DEVICE=cpu
